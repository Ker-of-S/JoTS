---
interface Props {
	category: string;
	title: string;
	authors: string;
	abstract: string;
	id: string;
}

const { category, title, authors, abstract, id } = Astro.props;
---

<article class="card">
    <div class="card-content">
        <span class="category">{category}</span>
        <h3>{title}</h3>
        <p class="authors">{authors}</p>
        <p class="abstract">{abstract}</p>
        
        <a href={`/publications/${id}`} class="read-more">Read Abstract</a>
    </div>
</article>

<style>
    .card {
        background: white;
        box-shadow: 0 4px 15px rgba(0,0,0,0.05);
        overflow: hidden;
        transition: transform 0.3s, box-shadow 0.3s;
    }

    .card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 25px rgba(0,0,0,0.1);
    }

    .card-content {
        padding: 2.5rem 2rem;
    }

    .category {
        display: inline-block;
        background-color: var(--blue2);
        color: var(--bg-color);
        padding: 0.3rem 0.8rem;
        font-size: 0.75rem;
        margin-bottom: 1rem;
        font-weight: bold;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    h3 {
        font-size: 1.4rem;
        margin-bottom: 0.8rem;
        color: var(--primary-blue);
        line-height: 1.3;
    }

    .authors {
        font-style: italic;
        color: var(--text-muted);
        margin-bottom: 1rem;
        font-size: 0.95rem;
    }

    .abstract {
        margin-bottom: 1.5rem;
        color: var(--gray1);
        font-size: 0.95rem;
    }

    .read-more {
        background: transparent;
        border: 2px solid var(--accent-cyan);
        color: var(--primary-blue);
        padding: 0.5rem 1.2rem;
        cursor: pointer;
        font-weight: bold;
        transition: all 0.3s;
    }

    .read-more:hover {
        background: var(--accent-cyan);
        color: white;
    }
</style>