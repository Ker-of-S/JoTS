---
// src/components/Navbar.astro
---

<nav class="navbar" id="main-nav">
    <div class="nav-container">
        <a href="/JoTS/" class="logo">
            J<span>o</span>TS
        </a>

        <ul class="nav-links">
            <li><a href="/JoTS/publications">Publications</a></li>
            <li><a href="/JoTS/archive">Archive</a></li>
            <li><a href="/JoTS/about">About</a></li>
            <li><a href="/JoTS/submit" class="btn-submit">Submit Paper</a></li>
        </ul>

        <button class="mobile-menu-toggle" aria-label="Toggle Menu" id="menu-toggle">
            <span class="bar"></span>
            <span class="bar"></span>
            <span class="bar"></span>
        </button>
    </div>

    <div class="mobile-overlay" id="mobile-menu">
        <ul class="mobile-links">
           <li><a href="/JoTS/publications">Publications</a></li>
            <li><a href="/JoTS/archive">Archive</a></li>
            <li><a href="/JoTS/about">About</a></li>
            <li><a href="/JoTS/submit" class="btn-submit">Submit Paper</a></li>
        </ul>
    </div>
</nav>

<style>
    .navbar {
        position: fixed;
        top: 0;
        width: 100%;
        z-index: 1000;
        padding: 1.2rem 5%;
        transition: all 0.4s ease;
        background-color: transparent;
    }

    .navbar.scrolled {
        background-color: var(--primary-blue); 
        padding: 0.8rem 5%;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.2);
    }

    .nav-container {
        max-width: 1200px;
        margin: 0 auto;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .logo {
        font-family: 'Georgia', serif;
        font-size: 1.4rem;
        font-weight: bold;
        color: white;
        text-decoration: none;
        letter-spacing: 2px;
    }

    .logo span {
        color: var(--accent-cyan);
        font-weight: 300;
    }

    .nav-links {
        display: flex;
        align-items: center;
        list-style: none;
        gap: 2rem;
    }

    .nav-links a {
        color: rgba(255, 255, 255, 0.85);
        text-decoration: none;
        font-size: 0.9rem;
        font-weight: 500;
        transition: color 0.3s ease;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .nav-links a:hover {
        color: var(--accent-cyan);
    }

    .btn-submit {
        background-color: var(--accent-cyan);
        color: var(--primary-blue) !important;
        padding: 0.6rem 1.2rem;
        border-radius: 4px;
        font-weight: bold !important;
        transition: transform 0.2s ease !important;
    }

    .btn-submit:hover {
        transform: scale(1.05);
        background-color: white;
    }

    .mobile-menu-toggle {
        display: none;
        flex-direction: column;
        gap: 6px;
        background: none;
        border: none;
        cursor: pointer;
        z-index: 1100;
    }

    .bar {
        width: 25px;
        height: 2px;
        background-color: white;
        transition: all 0.3s ease;
    }

    .mobile-overlay {
        position: fixed;
        top: 0;
        right: -100%;
        width: 100%;
        height: 100vh;
        background-color: var(--primary-blue);
        display: flex;
        justify-content: center;
        align-items: center;
        transition: right 0.5s cubic-bezier(0.77, 0.2, 0.05, 1);
    }

    .mobile-overlay.active {
        right: 0;
    }

    .mobile-links {
        list-style: none;
        text-align: center;
        display: flex;
        flex-direction: column;
        gap: 2.5rem;
    }

    .mobile-links a {
        color: white;
        text-decoration: none;
        font-size: 1.5rem;
        font-family: 'Georgia', serif;
    }

    @media (max-width: 768px) {
        .nav-links {
            display: none;
        }

        .mobile-menu-toggle {
            display: flex;
        }

        .mobile-menu-toggle.open .bar:nth-child(1) {
            transform: translateY(8px) rotate(45deg);
        }
        .mobile-menu-toggle.open .bar:nth-child(2) {
            opacity: 0;
        }
        .mobile-menu-toggle.open .bar:nth-child(3) {
            transform: translateY(-8px) rotate(-45deg);
        }
    }
</style>

<script>
    const nav = document.getElementById('main-nav');
    const menuToggle = document.getElementById('menu-toggle');
    const mobileMenu = document.getElementById('mobile-menu');

    if (nav) {
        window.addEventListener('scroll', () => {
            if (window.scrollY > 50) {
                nav.classList.add('scrolled');
            } else {
                nav.classList.remove('scrolled');
            }
        });
    }

    if (menuToggle && mobileMenu) {
        menuToggle.addEventListener('click', () => {
            menuToggle.classList.toggle('open');
            mobileMenu.classList.toggle('active');
            
            document.body.style.overflow = mobileMenu.classList.contains('active') ? 'hidden' : 'auto';
        });
    }

    const mobileLinks = document.querySelectorAll('.mobile-links a');
    mobileLinks.forEach(link => {
        link.addEventListener('click', () => {
            if (menuToggle) menuToggle.classList.remove('open');
            if (mobileMenu) mobileMenu.classList.remove('active');
            document.body.style.overflow = 'auto';
        });
    });
</script>