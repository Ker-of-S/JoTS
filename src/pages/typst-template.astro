        border-bottom: 4px solid var(--accent-cyan);
        text-align: center;
    }

    .hero-content {
        max-width: 800px;
        margin: 0 auto;
    }

    .template-hero h1 {
        color: white;
        font-family: 'Georgia', serif;
        font-size: 3rem;
        margin-bottom: 0.5rem;
    }

    .template-hero p {
        color: var(--blue2);
        font-size: 1.1rem;
    }

    .template-container {
        max-width: 1000px;
        margin: 0 auto;
        padding: 4rem 5%;
    }

    .instructions-panel {
        margin-bottom: 3rem;
    }

    .info-block {
        background-color: white;
        padding: 2rem;
        border: 1px solid var(--border-color, var(--clear1));
        border-left: 5px solid var(--blue3);
        box-shadow: 0 4px 15px rgba(0,0,0,0.03);
    }

    .info-block h3 {
        color: var(--primary-blue);
