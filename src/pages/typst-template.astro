---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Typst Template | Journal of Terminal Sciences">
    <Navbar />

    <header class="template-hero">
        <div class="hero-content">
            <h1>Typst Template</h1>
            <p>Standardized formatting for next-generation typesetting.</p>
        </div>
    </header>

    <main class="template-container">
        <section class="instructions-panel">
            <div class="info-block">
                <h3>Usage Instructions</h3>
                <p>To maintain the typographical and aesthetic standards of the Journal of Terminal Sciences, all manuscripts must be typeset using this Typst configuration.</p>
                <ul>
                    <li>Create the corresponding folder structure (<code>modules/</code>)</li>
                    <li>Navigate through the tabs below and copy the contents into their respective <code>.typ</code> files.</li>
                    <li>Ensure your final submission is compiled into a PDF document before attaching the link in the <a href="/submit">Submission Portal</a>.</li>
                </ul>
            </div>
        </section>

        <section class="code-section">
            <div class="terminal-window">
                <div class="terminal-tabs">
                    <button class="tab-btn active" data-file="main">main.typ</button>
                    <button class="tab-btn" data-file="template">template.typ</button>
                    <button class="tab-btn" data-file="boxes">modules/boxes.typ</button>
                    <button class="tab-btn" data-file="colors">modules/colors.typ</button>
                    <button class="tab-btn" data-file="math">modules/math.typ</button>
                </div>

                <div class="terminal-header">
                    <div class="terminal-title" id="active-filename">main.typ</div>
                    <button id="copyBtn" class="btn-copy">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
                        <span>Copy Code</span>
                    </button>
                </div>

                <div class="terminal-body">
                    <div id="main" class="code-pane active">
<pre><code>#import "template.typ": *
</code></pre>
                    </div>

                    <div id="template" class="code-pane">
<pre><code>// template.typ
</code></pre>
                    </div>

                    <div id="boxes" class="code-pane">
<pre><code>// modules/boxes.typ
</code></pre>
                    </div>

                    <div id="colors" class="code-pane">
<pre><code>// modules/colors.typ

</code></pre>
                    </div>

                    <div id="math" class="code-pane">
<pre><code>//modules/math.typ
</code></pre>
                    </div>
                </div>
            </div>
        </section>
    </main>

    <Footer />
</Layout>

<style>
    .template-hero {
        background-color: var(--primary-blue);
        padding: 8rem 5% 4rem 5%;
        border-bottom: 4px solid var(--accent-cyan);
        text-align: center;
    }

    .hero-content {
        max-width: 800px;
        margin: 0 auto;
    }

    .template-hero h1 {
        color: white;
        font-family: 'Georgia', serif;
        font-size: 3rem;
        margin-bottom: 0.5rem;
    }

    .template-hero p {
        color: var(--blue2);
        font-size: 1.1rem;
    }

    .template-container {
        max-width: 1000px;
        margin: 0 auto;
        padding: 4rem 5%;
    }

    .instructions-panel {
        margin-bottom: 3rem;
    }

    .info-block {
        background-color: white;
        padding: 2rem;
        border: 1px solid var(--border-color, var(--clear1));
        border-left: 5px solid var(--blue3);
        box-shadow: 0 4px 15px rgba(0,0,0,0.03);
    }

    .info-block h3 {
        color: var(--primary-blue);
        font-size: 1.3rem;
        margin-bottom: 1rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .info-block p, .info-block ul {
        color: var(--gray1, #444);
        font-size: 1.05rem;
        line-height: 1.6;
    }
    
    .info-block ul {
        padding-left: 1.5rem;
        margin-top: 1rem;
    }

    .info-block li {
        margin-bottom: 0.5rem;
    }

    .info-block a {
        color: var(--accent-cyan);
        font-weight: bold;
        text-decoration: none;
    }

    .info-block a:hover {
        text-decoration: underline;
    }

    code {
        background-color: var(--bg-color, #f4f4f4);
        padding: 0.2rem 0.4rem;
        font-family: 'Courier New', Courier, monospace;
        font-size: 0.9em;
        color: var(--primary-blue);
        border: 1px solid #ddd;
    }

    .terminal-window {
        background-color: var(--blue3);
        overflow: hidden;
        box-shadow: 0 10px 30px rgba(0,0,0,0.2);
        border: 1px solid var(--text-main, #333);
    }

    .terminal-tabs {
        display: flex;
        background-color: #1a1b26;
        border-bottom: 1px solid #2a2b3d;
        overflow-x: auto;
    }

    .tab-btn {
        background: transparent;
        color: #888;
        border: none;
        padding: 0.8rem 1.5rem;
        font-family: 'Courier New', Courier, monospace;
        font-size: 0.9rem;
        cursor: pointer;
        transition: all 0.2s;
        border-right: 1px solid #2a2b3d;
        white-space: nowrap;
    }

    .tab-btn:hover {
        background-color: #242533;
        color: #ccc;
    }

    .tab-btn.active {
        background-color: var(--blue3);
        color: var(--accent-cyan);
        border-bottom: 2px solid var(--accent-cyan);
    }

    .terminal-header {
        background-color: var(--blue3);
        padding: 1rem 1.5rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-bottom: 1px solid #2a2b3d;
    }

    .terminal-title {
        color: var(--blue1, #fff);
        font-family: 'Courier New', Courier, monospace;
        font-size: 0.9rem;
    }

    .btn-copy {
        background-color: rgba(47, 131, 158, 0.1);
        color: var(--accent-cyan);
        border: 1px solid rgba(47, 131, 158, 0.3);
        padding: 0.5rem 1rem;
        font-family: system-ui, sans-serif;
        font-weight: bold;
        font-size: 0.85rem;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 0.5rem;
        transition: all 0.2s;
    }

    .btn-copy:hover {
        background-color: var(--accent-cyan);
        color: var(--primary-blue);
    }

    .btn-copy.success {
        background-color: #9ece6a;
        color: var(--blue3);
        border-color: #9ece6a;
    }

    .terminal-body {
        padding: 1.5rem;
        overflow-x: auto;
    }

    .code-pane {
        display: none;
    }

    .code-pane.active {
        display: block;
    }

    .terminal-body::-webkit-scrollbar {
        height: 8px;
    }

    .terminal-body::-webkit-scrollbar-track {
        background: var(--blue3);
    }

    .terminal-body::-webkit-scrollbar-thumb {
        background: var(--accent-cyan);
    }

    pre {
        margin: 0;
        font-family: 'Courier New', Courier, monospace;
        font-size: 0.95rem;
        line-height: 1.5;
        color: var(--clear1, #e0e0e0);
    }

    @media (max-width: 768px) {
        .template-hero {
            padding: 6rem 5% 3rem 5%;
        }

        .template-hero h1 {
            font-size: 2.2rem;
        }

        .terminal-header {
            flex-direction: column;
            gap: 1rem;
            align-items: flex-start;
        }
    }
</style>

<script>
    const setupTerminalUI = () => {
        const tabs = document.querySelectorAll('.tab-btn');
        const panes = document.querySelectorAll('.code-pane');
        const copyBtn = document.getElementById('copyBtn');
        const activeFilename = document.getElementById('active-filename');

        if (!copyBtn || tabs.length === 0) return;

        tabs.forEach(tab => {
            tab.addEventListener('click', () => {
                tabs.forEach(t => t.classList.remove('active'));
                panes.forEach(p => p.classList.remove('active'));
                
                tab.classList.add('active');
                const targetId = tab.getAttribute('data-file');
                if(targetId) {
                    const targetPane = document.getElementById(targetId);
                    if(targetPane) targetPane.classList.add('active');
                }
                
                if(activeFilename) {
                    (activeFilename as HTMLElement).innerText = (tab as HTMLElement).innerText;
                }
            });
        });

        const newCopyBtn = copyBtn.cloneNode(true) as HTMLElement;
        if (copyBtn.parentNode) {
            copyBtn.parentNode.replaceChild(newCopyBtn, copyBtn);
        }
        
        newCopyBtn.addEventListener('click', async () => {
            try {
                const activePane = document.querySelector('.code-pane.active code') as HTMLElement;
                if (!activePane) return;
                
                const textToCopy = activePane.innerText || activePane.textContent;
                await navigator.clipboard.writeText(textToCopy);
                
                const originalHTML = newCopyBtn.innerHTML;
                newCopyBtn.classList.add('success');
                newCopyBtn.innerHTML = `
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
                    <span>Copied!</span>
                `;
                
                setTimeout(() => {
                    newCopyBtn.classList.remove('success');
                    newCopyBtn.innerHTML = originalHTML;
                }, 2000);

            } catch (err) {
                console.error('Failed to copy text: ', err);
                alert("Unable to copy to clipboard. Please copy manually.");
            }
        });
    };

    setupTerminalUI();
    
    document.addEventListener('astro:after-swap', setupTerminalUI);
</script>