        }

        .terminal-header {
            flex-direction: column;
            gap: 1rem;
            align-items: flex-start;
        }
    }
</style>

<script>
    const setupTerminalUI = () => {
        const tabs = document.querySelectorAll('.tab-btn');
        const panes = document.querySelectorAll('.code-pane');
        const copyBtn = document.getElementById('copyBtn');
        const activeFilename = document.getElementById('active-filename');

        if (!copyBtn || tabs.length === 0) return;

        tabs.forEach(tab => {
            tab.addEventListener('click', () => {
                tabs.forEach(t => t.classList.remove('active'));
                panes.forEach(p => p.classList.remove('active'));
                
                tab.classList.add('active');
                const targetId = tab.getAttribute('data-file');
                if(targetId) {
                    const targetPane = document.getElementById(targetId);
                    if(targetPane) targetPane.classList.add('active');
                }
                
                if(activeFilename) {
                    (activeFilename as HTMLElement).innerText = (tab as HTMLElement).innerText;
                }
            });
        });

        const newCopyBtn = copyBtn.cloneNode(true) as HTMLElement;
        if (copyBtn.parentNode) {
            copyBtn.parentNode.replaceChild(newCopyBtn, copyBtn);
        }
        
        newCopyBtn.addEventListener('click', async () => {
            try {
                const activePane = document.querySelector('.code-pane.active code2') as HTMLElement;
                if (!activePane) return;
                
                const textToCopy = activePane.innerText || activePane.textContent;
                await navigator.clipboard.writeText(textToCopy);
                
                const originalHTML = newCopyBtn.innerHTML;
                newCopyBtn.classList.add('success');
                newCopyBtn.innerHTML = `
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
                    <span>Copied!</span>
                `;
                
                setTimeout(() => {
                    newCopyBtn.classList.remove('success');
                    newCopyBtn.innerHTML = originalHTML;
                }, 2000);

            } catch (err) {
                console.error('Failed to copy text: ', err);
                alert("Unable to copy to clipboard. Please copy manually.");
            }
        });
    };

    setupTerminalUI();
    
    document.addEventListener('astro:after-swap', setupTerminalUI);
</script>