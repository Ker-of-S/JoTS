---
// src/pages/publications/[...page].astro
import type { Page } from 'astro';
import type { CollectionEntry } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths({ paginate }: { paginate: any}) {
    const allPublications = await getCollection('publications');
    
    return paginate(allPublications, { pageSize: 12 });
}

interface Props {
    page: Page<CollectionEntry<'publications'>>;
}

const { page } = Astro.props;

const allPublications = await getCollection('publications');

const searchData = allPublications.map(pub => ({
    id: pub.id,
    title: pub.data.title,
    category: pub.data.category,
    authors: pub.data.authors,
    abstract: pub.data.abstract
}));
const uniqueCategories = [...new Set(allPublications.map(pub => pub.data.category))].sort();
---

<Layout title="Journal Archive | JoTS">
    <Navbar />

    <header class="archive-hero">
        <div class="archive-hero-content">
            <h1>Journal Archive</h1>
            <p>Access the complete collection of peer-reviewed research, exploring the ultimate frontiers of knowledge.</p>
        </div>
    </header>

    <main class="publications-main">
 <section class="toolbar">
            <div class="search-box">
                <input type="text" id="searchInput" placeholder="Search by keyword or author..." />
                <button type="button">Search</button>
            </div>
            
            <div class="filters">
            <select id="categoryFilter">
                <option value="all">All Categories</option>
                    {uniqueCategories.map((category) => (
                <option value={category}>{category}</option>
                    ))}
            </select>
            </div>
        </section>

        <section class="archive-grid" id="gridContainer">
            {
                page.data.map((pub) => (
                    <ArticleCard 
                        category={pub.data.category} 
                        title={pub.data.title} 
                        authors={pub.data.authors} 
                        abstract={pub.data.abstract}
                        id={pub.id} 
                    />
                ))
            }
        </section>

        <div class="pagination" id="paginationWrapper">
        </div>

        {/* Page dynamics */}
        <div class="pagination">
            {page.url.prev ? (
                <a href={page.url.prev} class="page-btn">&laquo; Previous</a>
            ) : (
                <span class="page-btn disabled">&laquo; Previous</span>
            )}
            
            <span class="page-info">Page {page.currentPage} of {page.lastPage}</span>
            
            {page.url.next ? (
                <a href={page.url.next} class="page-btn">Next &raquo;</a>
            ) : (
                <span class="page-btn disabled">Next &raquo;</span>
            )}
        </div>
    </main>

    <Footer />
</Layout>

<style>
    .archive-hero {
        background-color: var(--primary-blue); 
        padding: 8rem 5% 4rem 5%; 
        text-align: center;
        color: white;
        border-bottom: 4px solid var(--accent-cyan); 
    }

    .archive-hero-content h1 {
        font-family: 'Georgia', serif;
        font-size: 3rem;
        margin-bottom: 1rem;
    }

    .archive-hero-content p {
        font-size: 1.1rem;
        color: var(--blue2);
        max-width: 600px;
        margin: 0 auto;
    }

    .publications-main {
        max-width: 1200px;
        margin: 0 auto;
        padding: 3rem 5%;
    }

    .toolbar {
        display: flex;
        flex-wrap: wrap;
        justify-content: space-between;
        align-items: center;
        gap: 1.5rem;
        margin-bottom: 3rem;
        background: white;
        padding: 1.5rem;
        box-shadow: 0 4px 15px rgba(0,0,0,0.05);
    }

    .search-box {
        display: flex;
        flex: 1;
        min-width: 300px;
    }

    .search-box input {
        width: 100%;
        padding: 0.8rem 1rem;
        border: 1px solid #ccc;
        outline: none;
        font-size: 1rem;
    }

    .search-box input:focus {
        border-color: var(--accent-cyan);
    }

    .search-box button {
        padding: 0.8rem 1.5rem;
        background-color: var(--primary-blue);
        color: white;
        border: none;
        cursor: pointer;
        font-weight: bold;
        transition: background-color 0.3s;
    }

    .search-box button:hover {
        background-color: var(--accent-cyan);
        color: var(--primary-blue);
    }

    .filters {
        display: flex;
        gap: 1rem;
    }

    .filters select {
        padding: 0.8rem;
        border: 1px solid #ccc;
        outline: none;
        background-color: white;
        cursor: pointer;
        font-size: 0.95rem;
    }

    .archive-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
        gap: 2.5rem;
        margin-bottom: 4rem;
    }

    .pagination {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 1.5rem;
        margin-bottom: 2rem;
    }

    .page-btn {
        display: inline-block;
        padding: 0.6rem 1.2rem;
        background-color: transparent;
        border: 2px solid var(--primary-blue);
        color: var(--primary-blue);
        cursor: pointer;
        font-weight: bold;
        text-decoration: none;
        transition: all 0.3s;
    }

    a.page-btn:hover {
        background-color: var(--primary-blue);
        color: white;
    }

    span.page-btn.disabled {
        border-color: #ccc;
        color: #ccc;
        cursor: not-allowed;
        background-color: transparent;
    }

    .page-info {
        font-weight: bold;
        color: var(--gray1);
    }

    @media (max-width: 768px) {
        .archive-hero {
            padding: 6rem 5% 3rem 5%;
        }

        .archive-hero-content h1 {
            font-size: 2.2rem;
        }

        .archive-hero-content p {
            font-size: 1.05rem;
        }

        .publications-main {
            padding: 2rem 5%;
        }

        .toolbar {
            flex-direction: column;
            align-items: stretch;
            padding: 1rem;
            gap: 1rem;
            margin-bottom: 2rem;
        }

        .search-box {
            min-width: 100%;
        }

        .search-box {
            flex-direction: column;
        }

        .search-box input {
            margin-bottom: 0.5rem;
            border-right: 1px solid #ccc;
        }

        .search-box button {
            width: 100%;
        }

        .filters {
            flex-direction: column;
            width: 100%;
        }

        .filters select {
            width: 100%;
        }

        .archive-grid {
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 1.5rem;
            margin-bottom: 3rem;
        }

        .pagination {
            flex-wrap: wrap;
            gap: 1rem;
        }
        
        .page-btn {
            padding: 0.5rem 1rem;
            font-size: 0.9rem;
        }
    }
</style>

<script define:vars={{ searchData }}>
    const searchInput = document.getElementById('searchInput');
    const categoryFilter = document.getElementById('categoryFilter');
    const gridContainer = document.getElementById('gridContainer');
    const paginationWrapper = document.getElementById('paginationWrapper');
    
    const originalHTML = gridContainer.innerHTML;

    function renderResults(results) {
        if (results.length === 0) {
            gridContainer.innerHTML = '<p style="grid-column: 1/-1; text-align: center; color: var(--text-muted); font-size: 1.2rem;">No matching publications found.</p>';
            return;
        }

        gridContainer.innerHTML = results.map(pub => `
            <article class="card">
                <div class="card-content">
                    <span class="category">${pub.category}</span>
                    <h3 style="font-size: 1.4rem; margin-bottom: 0.8rem; color: var(--primary-blue); line-height: 1.3;">${pub.title}</h3>
                    <p style="font-style: italic; color: var(--text-muted); margin-bottom: 1rem; font-size: 0.95rem;">${pub.authors}</p>
                    <p style="margin-bottom: 1.5rem; color: var(--gray1); font-size: 0.95rem;">${pub.abstract}</p>
                    <a href="/publications/${pub.id}" class="read-more" style="background: transparent; border: 2px solid var(--accent-cyan); color: var(--primary-blue); padding: 0.5rem 1.2rem; cursor: pointer; font-weight: bold; text-decoration: none; display: inline-block;">Read Abstract</a>
                </div>
            </article>
        `).join('');
    }

    function handleSearch() {
        const query = searchInput.value.toLowerCase();
        const category = categoryFilter.value;

        if (query === '' && category === 'all') {
            gridContainer.innerHTML = originalHTML;
            paginationWrapper.style.display = 'flex';
            return;
        }

        paginationWrapper.style.display = 'none';

        const filtered = searchData.filter(pub => {
            const matchesQuery = pub.title.toLowerCase().includes(query) || 
                                 pub.authors.toLowerCase().includes(query) || 
                                 pub.abstract.toLowerCase().includes(query);
            
            const matchesCategory = category === 'all' || pub.category === category;
            
            return matchesQuery && matchesCategory;
        });

        renderResults(filtered);
    }

    searchInput.addEventListener('input', handleSearch);
    categoryFilter.addEventListener('change', handleSearch);
</script>