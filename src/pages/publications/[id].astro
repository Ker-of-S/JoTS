---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
    const publications = await getCollection('publications');
    return publications.map(entry => ({
        params: { id: entry.id },
        props: { entry },
    }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<Layout title={`${entry.data.title} | JoTS`} description={entry.data.abstract}>
    <Navbar />

    <main class="article-container">
        <header class="article-header">
            <span class="category-badge">{entry.data.category}</span>
            <h1>{entry.data.title}</h1>
            <p class="authors">{entry.data.authors}</p>
        </header>

        <section class="overview-content">
            <h3>Abstract / Overview</h3>
            
            <div class="markdown-body">
                <Content />
            </div>

            {entry.data.pdfUrl && (
                <div class="download-section">
                    <a href={entry.data.pdfUrl} target="_blank" rel="noopener noreferrer" class="btn-download">
                        Download Full PDF
                    </a>
                </div>
            )}
        </section>
    </main>

    <Footer />
</Layout>

<style>
    .article-container {
        max-width: 800px;
        margin: 0 auto;
        padding: 8rem 5% 4rem;
    }

    .article-header {
        text-align: center;
        margin-bottom: 3rem;
        padding-bottom: 2rem;
        border-bottom: 1px solid var(--clear1);
    }

    .category-badge {
        background-color: var(--bg-color);
        color: var(--accent-cyan);
        padding: 0.4rem 1rem;
        font-size: 0.8rem;
        font-weight: bold;
        text-transform: uppercase;
        letter-spacing: 1px;
        display: inline-block;
        margin-bottom: 1rem;
    }

    .article-header h1 {
        font-family: 'Georgia', serif;
        font-size: 2.5rem;
        color: var(--primary-blue);
        margin-bottom: 1rem;
        line-height: 1.3;
    }

    .authors {
        font-style: italic;
        color: var(--text-muted);
        font-size: 1.1rem;
    }

    .overview-content h3 {
        color: var(--primary-blue);
        margin-bottom: 1rem;
    }

    .markdown-body {
        font-size: 1.1rem;
        line-height: 1.8;
        color: #444;
        margin-bottom: 3rem;
    }

    .download-section {
        text-align: center;
        margin-top: 3rem;
        padding: 2rem;
        background-color: var(--bg-color);
    }

    .btn-download {
        background-color: var(--primary-blue);
        color: white;
        padding: 1rem 2rem;
        text-decoration: none;
        font-weight: bold;
        transition: background-color 0.3s;
        display: inline-block;
    }

    .btn-download:hover {
        background-color: var(--accent-cyan);
        color: var(--primary-blue);
    }

    @media (max-width: 768px) {
        .article-container {
            padding: 6rem 5% 2rem;
        }

        .article-header {
            margin-bottom: 2rem;
            padding-bottom: 1.5rem;
        }

        .article-header h1 {
            font-size: 1.8rem;
        }

        .authors {
            font-size: 1rem;
        }

        .markdown-body {
            font-size: 1.05rem;
        }

        .download-section {
            padding: 1.5rem 1rem;
        }
        
        .btn-download {
            width: 100%;
            padding: 0.8rem 1rem;
        }
    }
</style>