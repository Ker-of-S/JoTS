---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Submit Manuscript | Journal of Terminal Sciences">
    <Navbar />

    <header class="submit-hero">
        <div class="hero-content">
            <h1>Manuscript Submission</h1>
            <p>JoTS submission page.</p>
        </div>
    </header>

    <main class="submit-main">
        
        <section class="prerequisite-section">
            <div class="alert-box">
                <div class="alert-icon">!</div>
                <div class="alert-text">
                    <h3>Prerequisite</h3>
                    <p>Before proceeding with your submission, you must read the <a href="/JoTS/guidelines">Author Guidelines</a>. Submissions that do not strictly adhere to these protocols will be automatically rejected.</p>
                </div>
            </div>
        </section>

        <section class="specifications-section">
            <div class="specs-content">
                <h2>Format Specifications</h2>
                
                <div class="user-specs">
                    <p>To ensure the integrity of our databases, all online projects and documents submitted via shareable links (e.g., Google Docs, Overleaf) must be strictly set to "Read-Only" mode.</p>
                    <h3>General specifications</h3>
                    <ul>
                        <li>Page Dimensions: Standard A4 or US Letter sizes.</li>
                        <li>A two-column structure is recommended, unless large objects (such as extensive data tables, schematics, or diagrams) require full-page width.</li>
                        <li>Margins and Indentation: Arbitrary, but authors are expected to use their best judgment to maintain a clean appearance without exaggeration.</li>
                        <li>Primary Text Color: Standard black.</li>
                    </ul>

                    <h3><span class="icon">LaTeX</span> Submissions</h3>
                    <ul>
                        <li>Typography and Sizing: The default LaTeX font and size are preferred. Minor adjustments for visual comfort or specific structural needs are permitted.</li>
                        <li>Styling: Colors, custom designs, and additional visual elements are completely free, provided they serve the document's purpose and do not compromise data legibility.</li>
                    </ul>

                    <h3>Standard Word Processors (Microsoft Word, Google Docs, etc.)</h3>
                    <ul>
                        <li>Typography: Manuscripts should use IBM Plex Serif, EB Garamond, Lora, Computer Modern, or AMS fonts. We recommend maintaining a single font family throughout the document, unless a distinct environment (such as data logs or code blocks) requires differentiation.</li>
                        <li>Alternative Fonts: If you choose to use a font not listed above, you must verify that it is in the public domain or explicitly licensed for non-commercial use (e.g., Open Font License).</li>
                        <li>Mathematical Equations: The native equation font provided by your chosen word processor is perfectly acceptable.</li>
                        <li><b>Font Size</b>
                        <ul>
                            <li>Article Title: 17-18 pt (Regular or Bold)</li>
                            <li>Author(s): 12 pt</li>
                            <li>Abstract Header: 10 pt (Bold)</li>
                            <li>Abstract Text: 9 pt</li>
                            <li>Section Headers: 14-15 pt (Bold)</li>
                            <li>Subsection Headers: 12-13 pt (Bold)</li>
                            <li>Main text: 10 pt</li>
                            <li>Footnotes: 8 pt</li>
                            <li>Captions: 9 pt</li>
                        </ul>
                        </li>
                        <li>Color Usage: Arbitrary colors are permitted for headings or specific elements, but they must remain legible and preserve a professional style.</li>
                    </ul>
                </div>

                <div class="template-action">
                    <p>To ensure compliance, please use our typesetting environment:</p>
                    <a href="/JoTS/latex-template" class="btn-latex">
                        <span class="icon">ΤΕΧ</span> Access Official LaTeX Template
                    </a>
                    <p><em>Coming soon: proposals on a wiki site.</em></p>
                </div>
            </div>
        </section>

        <section class="form-section">
            <div class="iframe-container">
                <iframe 
                    src="https://docs.google.com/forms/d/e/1FAIpQLSfIeb0zRo_teO6wws7mpEV1OcXwC0_iEFoOlPg340KTzrJ6vw/viewform?embedded=true" 
                    width="100%" 
                    height="900" 
                    frameborder="0" 
                    marginheight="0" 
                    marginwidth="0">
                    Loading form...
                </iframe>
            </div>
        </section>

    </main>

    <Footer />
</Layout>

<style>
    .submit-hero {
        background-color: var(--primary-blue);
        padding: 8rem 5% 4rem 5%;
        border-bottom: 4px solid var(--accent-cyan);
        text-align: center;
    }

    .hero-content {
        max-width: 800px;
        margin: 0 auto;
    }

    .submit-hero h1 {
        color: white;
        font-family: 'Georgia', serif;
        font-size: 3rem;
        margin-bottom: 0.5rem;
    }

    .submit-hero p {
        color: var(--blue2);
        font-size: 1.1rem;
    }

    .submit-main {
        max-width: 900px;
        margin: 0 auto;
        padding: 4rem 5%;
    }

    .prerequisite-section {
        margin-bottom: 4rem;
    }

    .alert-box {
        display: flex;
        align-items: flex-start;
        gap: 1.5rem;
        background-color: rgba(255, 77, 77, 0.05);
        border: 1px solid rgba(255, 77, 77, 0.3);
        border-left: 5px solid #ff4d4d;
        padding: 2rem;
    }

    .alert-icon {
        background-color: #ff4d4d;
        color: white;
        font-family: 'Courier New', Courier, monospace;
        font-size: 1.5rem;
        font-weight: bold;
        width: 40px;
        height: 40px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .alert-text h3 {
        color: var(--red1);
        margin-bottom: 0.5rem;
        font-size: 1.2rem;
        font-family: system-ui, sans-serif;
    }

    .alert-text p {
        color: var(--text-main);
        font-size: 1.05rem;
        line-height: 1.6;
        margin: 0;
    }

    .alert-text a {
        color: var(--primary-blue);
        font-weight: bold;
        text-decoration: underline;
        text-decoration-color: var(--accent-cyan);
        text-decoration-thickness: 2px;
        transition: color 0.3s;
    }

    .alert-text a:hover {
        color: var(--accent-cyan);
    }

    .specifications-section {
        background: white;
        padding: 3rem;
        box-shadow: 0 4px 15px rgba(0,0,0,0.03);
        border: 1px solid var(--border-color, var(--clear1));
        margin-bottom: 4rem;
    }

    .specs-content h2 {
        font-family: 'Georgia', serif;
        color: var(--primary-blue);
        font-size: 2rem;
        margin-bottom: 1.5rem;
        border-bottom: 1px solid #eee;
        padding-bottom: 0.5rem;
    }

    .user-specs {
        color: var(--gray1);
        font-size: 1.05rem;
        line-height: 1.7;
        margin-bottom: 2.5rem;
    }

    .user-specs ul {
        margin-top: 1rem;
        padding-left: 1.5rem;
    }

    .user-specs li {
        margin-bottom: 0.5rem;
    }

    .template-action {
        background-color: var(--bg-color);
        padding: 2rem;
        text-align: center;
        border: 1px dashed #ccc;
    }

    .template-action p {
        color: var(--text-main);
        margin-bottom: 1.5rem;
        font-weight: 500;
    }

    .btn-latex {
        display: inline-flex;
        align-items: center;
        gap: 0.8rem;
        background-color: var(--primary-blue);
        color: white;
        padding: 1rem 2rem;
        text-decoration: none;
        font-weight: bold;
        font-size: 1.1rem;
        transition: transform 0.2s, background-color 0.3s;
    }

    .btn-latex .icon {
        font-family: 'Times New Roman', Times, serif;
        font-size: 1.3rem;
        letter-spacing: -1px;
    }

    .btn-latex:hover {
        background-color: var(--accent-cyan);
        color: var(--primary-blue);
        transform: translateY(-2px);
    }

    .form-section {
        background: white;
        padding: 1rem;
        box-shadow: 0 4px 20px rgba(0,0,0,0.05);
        border: 1px solid var(--border-color, var(--clear1));
        overflow: hidden;
    }

    .iframe-container {
        width: 100%;
        position: relative;
    }

    .iframe-container iframe {
        display: block;
        width: 100%;
        border: none;
    }

    @media (max-width: 768px) {
        .submit-hero {
            padding: 6rem 5% 3rem 5%;
        }

        .submit-hero h1 {
            font-size: 2.2rem;
        }

        .alert-box {
            flex-direction: column;
            gap: 1rem;
            padding: 1.5rem;
        }

        .specifications-section {
            padding: 1.5rem;
        }

        .btn-latex {
            width: 100%;
            justify-content: center;
        }

        .iframe-container iframe {
            height: 1200px;
        }
    }
</style>