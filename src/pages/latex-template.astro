import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const LatexC = `% ======================================
%  JoTS Template - Medium Edition
%  Version: 1.0  |  Date: \today
% ======================================
\\documentclass[11pt, a4paper, twoside]{article}

\\usepackage{lipsum}

% ===================================
%  1. ENCODING & LANGUAGE
% ===================================
\\usepackage[utf8]{inputenc}
\\usepackage[T1]{fontenc}
\\usepackage[english]{babel}
\\usepackage{microtype}

% ==================================
%  2. PAGE GEOMETRY & LAYOUT
% ==================================
\\usepackage[
  margin=24mm,
  headheight=14pt,
  includeheadfoot
]{geometry}

\\usepackage{fancyhdr}
\\pagestyle{fancy}
\\fancyhf{}
\\fancyhead[LE,RO]{\\small\\thepage}
\\fancyfoot[C]{\\small\\textcolor{gray!70}{$\\mathcal{J}${'{'}\\fontfamily{cmss}\\selectfont o${'}'}TS | Journal of Terminal Sciences \\textemdash\\ Short Running Title}}
\\renewcommand{\\headrulewidth}{0.4pt}
\\renewcommand{\\footrulewidth}{0.2pt}

% ==================================
%  3. COLOR PALETTE
% ==================================
\\usepackage[dvipsnames, svgnames, x11names, table]{xcolor}

\\definecolor{PrimaryBlue}{HTML}{041225}
\\definecolor{AccentCyan}{HTML}{65C7C6}
\\definecolor{AccentGreen}{HTML}{27AE60}
\\definecolor{AccentOrange}{HTML}{E67E22}
\\definecolor{AccentRed}{HTML}{814641}
\\definecolor{NoteCol}{HTML}{173F8E}
\\definecolor{DangerCol}{HTML}{8B0000}
\\definecolor{LightGray}{HTML}{F4F4F4}
\\definecolor{DarkGray}{HTML}{333333}
\\definecolor{CodeBg}{HTML}{F0F0F0}
\\definecolor{LinkColor}{HTML}{071F4E}

% ================================
%  4. MATHEMATICS & PHYSICS
% ================================
\\usepackage{amsmath, amssymb, amsthm, amsfonts}
\\usepackage{mathtools}
\\usepackage{physics}
\\usepackage{siunitx}
\\sisetup{
  overwrite-functions = true,
  per-mode            = symbol,
  range-phrase        = --,
  list-final-separator = {, and },
}

% Theorem-like environments
\\theoremstyle{definition}
\\newtheorem{definition}{Definition}[section]
\\theoremstyle{plain}
\\newtheorem{theorem}{Theorem}[section]

% Math shortcuts
\\newcommand{\\R}{\\mathbb{R}}
\\newcommand{\\normm}[1]{\\left\\lVert #1 \\right\\rVert}

% ================================
%  5. GRAPHICS, TABLES & ICONS
% ================================
\\usepackage{graphicx}
\\usepackage{fontawesome5}
\\usepackage{booktabs}
\\usepackage{multirow}
\\usepackage{multicol}
\\usepackage{caption}
\\captionsetup{
  font        = small,
  labelfont   = {bf, color=PrimaryBlue},
  labelsep    = period
}

% ================================
%  6. CUSTOM CALLOUT BOXES
% ================================
\\usepackage[most]{tcolorbox}
\\tcbuselibrary{skins, breakable}

% Info box
\\newtcolorbox{infobox}[1][]{
  enhanced, breakable, sharp corners,
  colback   = NoteCol!8, colframe = NoteCol,
  fonttitle = \\bfseries\\small,
  title     = \\textcolor{white}{\\faInfoCircle\\enspace Note},
  attach boxed title to top left = {yshift=-2mm, xshift=4mm},
  boxed title style = {colback=NoteCol, sharp corners},
  #1
}

% Danger box
\\newtcolorbox{dangerbox}[1][]{
  enhanced, breakable, sharp corners,
  colback   = DangerCol!8, colframe = DangerCol,
  fonttitle = \\bfseries\\small,
  title     = \\textcolor{white}{\\faTimes\\enspace Danger},
  attach boxed title to top left = {yshift=-2mm, xshift=4mm},
  boxed title style = {colback=DangerCol, sharp corners},
  #1
}

% Definition box
\\newtcolorbox{defbox}[2][]{
  enhanced, breakable, sharp corners,
  colback   = PrimaryBlue!6, colframe = PrimaryBlue,
  fonttitle = \\bfseries\\small,
  title     = Definition: #2,
  attach boxed title to top left = {yshift=-2mm, xshift=4mm},
  boxed title style = {colback=PrimaryBlue, sharp corners},
  #1
}

% ================================
%  7. CODE LISTINGS
% ================================
\\usepackage{listings}
\\lstset{
  basicstyle      = \\ttfamily\\footnotesize,
  backgroundcolor = \\color{CodeBg},
  frame           = single,
  framerule       = 0.4pt,
  rulecolor       = \\color{gray!50},
  keywordstyle    = \\color{PrimaryBlue}\\bfseries,
  commentstyle    = \\color{AccentGreen}\\itshape,
  stringstyle     = \\color{AccentRed},
  numberstyle     = \\tiny\\color{gray},
  numbers         = left,
  breaklines      = true
}

% =================================
%  8. HYPERLINKS & CROSS-REFERENCES
% =================================
\\usepackage[
  colorlinks  = true,
  linkcolor   = LinkColor,
  citecolor   = AccentGreen,
  urlcolor    = LinkColor,
  filecolor   = AccentOrange,
  bookmarks   = true,
]{hyperref}

\\usepackage{cleveref}
\\crefformat{equation}{(#2#1#3)}
\\crefname{figure}{Fig.}{Figs.}
\\crefname{table}{Table}{Tables}
\\crefname{section}{Section}{Sections}

% ================================
%  DOCUMENT BEGIN
% ================================
\\begin{document}

% ================================
%  TITLE BLOCK
% ================================
\\begin{center}
  {\\small\\color{gray}\$\\mathcal{J}\${\\fontfamily{cmss}\\selectfont o}TS | \\textit{Journal of Terminal Sciences}}\\par\\vspace{0.3cm}

  {\\LARGE\\bfseries\\color{PrimaryBlue}
    A Very Epic Title Goes Here
  }\\par\\vspace{0.23cm}

  % Authors
  \\begin{tabular}{c c}
    \\textbf{First Author}$^{1,\\dagger}$ & \\textbf{Second Author}$^{2}$ \\\\[4pt]
    \\small\\textit{Department of X, University A} & \\small\\textit{Institute of Y, Organisation B} \\\\
    \\small\\href{mailto:first@uni.edu}{first@uni.edu} & \\small\\href{mailto:second@org.com}{second@org.com}
  \\end{tabular}\\par\\vspace{0.23cm}

  {\\small$^{1}$University A, City, Country\\quad
         $^{2}$Organisation B, City, Country\\\\
   $^{\\dagger}$Corresponding author}\\par\\vspace{0.4cm}

  \\hrule height 0.4pt\\vspace{0.4cm}

  % Abstract
  \\begin{minipage}{0.85\\linewidth}
    \\small\\textbf{\\color{PrimaryBlue}Abstract.}\\enspace
    \\lipsum[100]
  \\end{minipage}\\par\\vspace{0.23cm}
\\end{center}
\\thispagestyle{plain}

% ================================
%  MAIN CONTENT
% ================================
\\begin{multicols}{2}
\\section{Introduction}

Scientific writing demands clarity and precision. We can easily reference \\cref{eq:navier}

\\begin{infobox}
  This template retains the \\textbf{NoteCol} blue and the FontAwesome icons for a professional look.
\\end{infobox}

\\section{Mathematical Notation}

The momentum equation for an incompressible fluid is shown below:

\\begin{equation}
  \\rho\\left(\\frac{\\partial \\mathbf{u}}{\\partial t} + \\mathbf{u}\\cdot\\nabla\\mathbf{u}\\right) = -\\nabla p + \\mu\\,\\nabla^2\\mathbf{u} + \\mathbf{f}
  \\label{eq:navier}
\\end{equation}

You can also define custom boxes with mandatory arguments correctly:

\\begin{defbox}{Lipschitz Continuity}
  A function $f: \\R^n \\to \\R^m$ is \\emph{$L$-Lipschitz} if there exists $L \\geq 0$ such that $\\normm{f(\\mathbf{x}) - f(\\mathbf{y})} \\leq L\\normm{\\mathbf{x} - \\mathbf{y}}$.
\\end{defbox}

\\section{Code Listings and Warnings}

\\begin{dangerbox}
  Never commit API keys or credentials to a public repository.
\\end{dangerbox}

\\begin{lstlisting}[language=Python, caption={Python standard training loop snippet.}]
def train_model(model, optimizer):
    model.train()
    # CodeBg, PrimaryBlue keywords, AccentGreen comments
    return True
\\end{lstlisting}

\\lipsum[20]

\\end{multicols}
\\end{document}
`;

